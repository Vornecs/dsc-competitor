    "fastify": "latest",
    "livekit-server-sdk": "2.16.0",
    "pg": "latest",
    "redis": "6.0.1",
    "resend": "6.16.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/ws": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "ws": "latest"
  }
