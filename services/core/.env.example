# Network interface the core HTTP server binds to.
HOST=127.0.0.1
# TCP port the core HTTP server listens on.
PORT=8790

# PostgreSQL connection string for durable staging and production storage.
DATABASE_URL=postgres://cove:cove@127.0.0.1:5432/cove
# Redis connection string for shared multi-node coordination.
REDIS_URL=redis://127.0.0.1:6379

# Local snapshot path used for persistence when DATABASE_URL is unset.
SNAPSHOT_FILE=.cove-data.json

# LiveKit WebSocket URL used for voice and screen sharing.
LIVEKIT_URL=ws://127.0.0.1:7880
# LiveKit API key used to sign room access tokens.
LIVEKIT_API_KEY=devkey
# LiveKit API secret used to sign room access tokens.
LIVEKIT_API_SECRET=replace-with-a-secret

# Built web-app directory served by the core service in integrated deployments.
WEB_DIST_DIR=../../apps/web/dist
# Comma-separated browser origins allowed to call the core API.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Bearer token required by the operator backup and restore endpoints.
OPERATOR_KEY=replace-with-a-long-random-secret

# Resend API key used to deliver email verification codes.
RESEND_API_KEY=re_replace-with-a-resend-api-key
# Sender address used for Cove authentication emails.
EMAIL_FROM=noreply@cove.demonbox360.net
