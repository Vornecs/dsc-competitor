# Core API and integrated preview
HOST=127.0.0.1
PORT=8790

# Set only when the browser client is hosted separately without the Vite proxy.
# VITE_API_URL=http://127.0.0.1:8790
# VITE_GATEWAY_URL=ws://127.0.0.1:8790/v1/gateway

# Exact comma-separated browser origins allowed when the web client is hosted separately.
# Same-origin production deployment should leave this unset.
# CORS_ALLOWED_ORIGINS=https://cove.example

# Serve the built Vite client from the core process in a same-origin deployment.
# WEB_DIST_DIR=./apps/web/dist
